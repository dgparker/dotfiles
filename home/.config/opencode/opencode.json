{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin-macchiato",
  "model": "qwen/nvidia/Qwen3.6-35B-A3B-NVFP4",
  "small_model": "qwen/nvidia/Qwen3.6-35B-A3B-NVFP4",
  "instructions": ["AGENTS.md"],
  "permission": {
    "websearch": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen Codecave",
      "options": {
        "baseURL": "http://qwen.codecave.local/v1"
      },
      "models": {
        "nvidia/Qwen3.6-35B-A3B-NVFP4": {
          "name": "Qwen3.6 35B NVFP4",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  }
}
